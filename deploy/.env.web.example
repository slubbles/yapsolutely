NEXT_PUBLIC_APP_NAME=Yapsolutely
NEXT_PUBLIC_APP_URL=https://app.example.com

AUTH_SECRET=replace-with-long-random-secret
DEMO_AUTH_ENABLED=true
RUNTIME_SHARED_SECRET=replace-with-shared-runtime-secret

ANTHROPIC_API_KEY=replace-with-anthropic-key
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_MAX_TOKENS=220

DEEPGRAM_API_KEY=replace-with-deepgram-key
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_ENDPOINTING_MS=300
DEEPGRAM_UTTERANCE_END_MS=800
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=+15555555555
TWILIO_SMS_FROM_NUMBER=+15555555555
TRANSFER_NUMBER=

VOICE_PIPELINE_MODE=live
VOICE_STREAM_BASE_URL=https://voice.example.com
VOICE_STREAM_WSS_URL=wss://voice.example.com/twilio/stream
VOICE_MODEL=aura-2-thalia-en

RECORDING_ENABLED=false