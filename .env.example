# Web application
NEXT_PUBLIC_APP_NAME="Yapsolutely"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-long-random-secret"
DEMO_AUTH_ENABLED="true"

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

RUNTIME_SHARED_SECRET="replace-with-runtime-shared-secret"

# Database / Supabase
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/yapsolutely"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/yapsolutely"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Voice / AI providers
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-5-haiku-latest"
ANTHROPIC_MAX_TOKENS="220"
DEEPGRAM_API_KEY="your-deepgram-api-key"
DEEPGRAM_STT_MODEL="nova-3"
DEEPGRAM_STT_ENDPOINTING_MS="300"
DEEPGRAM_UTTERANCE_END_MS="800"
DEEPGRAM_TTS_MODEL="aura-2-thalia-en"
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+10000000000"
TWILIO_SMS_FROM_NUMBER="+10000000000"
TRANSFER_NUMBER="+10000000001"
VOICE_STREAM_BASE_URL="your-voice-runtime-domain.com"
VOICE_STREAM_WSS_URL="wss://your-voice-runtime-domain.com/twilio/stream"
VOICE_PIPELINE_MODE="mock"
VOICE_MODEL="aura-2-thalia-en"

# App behavior
RECORDING_ENABLED="false"
